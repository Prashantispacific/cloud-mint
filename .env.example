# Master password hash (SHA-256 hex or bcrypt hash)
MINT_HASHED_PASSWORD=your_64_char_sha256_or_bcrypt_hash_here

# GitHub Personal Access Token (PAT) with repo scope
MINT_GITHUB_PAT=ghp_your_github_pat_here

# Optional: Default repository details (if left blank, the login screen will prompt you dynamically)
MINT_GITHUB_OWNER=
MINT_GITHUB_REPO=
MINT_GITHUB_BRANCH=main
